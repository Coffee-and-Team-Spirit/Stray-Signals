[background arg="res://assets/temp/tempCafe/Cafe_Interior.jpg" fade="1.5"]
if {Drink.Rating} == "none":
	jump begin_timeline
else:
	jump drink_rating
label begin_timeline
audio music "res://assets/audio/cafe_bgm.ogg" [fade="2.0" volume="-8.0"]
# DAY #, SCENE #
join  center
Oh my gosh, hello!
Player: Hi. It's all good. I'm doing okay. Things have been strange of late, but I enjoy my job.
[signal arg="drink_hint"]
**DRINK HINT HERE**
leave 
[signal arg="craft_drink"]
label drink_rating (Scene 2 Drink Rating)
[background arg="res://assets/temp/tempCafe/Cafe_Interior.jpg" fade="1.5" wait="true"]
audio music "res://assets/audio/craft_drink_bgm.ogg" [fade="2.0" volume="-5.0"]
if {Drink.Rating} == "mediocre":
	join  center
	**FINAL DRINK CLUE** for mediocre drink
	leave 
	[signal arg="clear_drink"]
elif {Drink.Rating} == "good":
	join  center
	**FINAL DRINK CLUE** for perfect/good drink
	leave 
	[signal arg="clear_drink"]
else:
	# Bad
	join  center
	I don't mean to be rude, but can I perhaps have another drink? Something feels a little off with mine.
	leave 
	[signal arg="clear_drink"]
	[signal arg="craft_drink"]
[background arg="res://assets/art/backgrounds/black_bg.png" fade="1.5"]
DayTransition: DAY 2
[signal arg="hide_textbox"]
[signal arg="end_encounter"]
[end_timeline]